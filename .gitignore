# Terraform state files (contain sensitive data, never commit)
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Variable override files (may contain secrets)
*.auto.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan output files
*.tfplan

# OS files
.DS_Store
Thumbs.db

# IDE files
.idea/
.vscode/
*.swp
*.swo
